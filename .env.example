# Copy to `.env` and fill in. `.env` is gitignored ‚Äî never commit real keys.

# Google Gemini API key ‚Äî free tier, no card: https://aistudio.google.com ("Get API key")
# Used for invoice extraction (see decisions D8).
GEMINI_API_KEY=

# Postgres connection string ‚Äî free: https://neon.tech (new project -> copy connection string)
DATABASE_URL=

# Vercel Blob read/write token ‚Äî https://vercel.com (Storage -> Blob).
# Needed for PDF upload/storage; can be left blank until that phase.
BLOB_READ_WRITE_TOKEN=
