# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.

# Google Gemini API key — free tier, no card: https://aistudio.google.com ("Get API key")
# Used for invoice extraction (see decisions D8).
GEMINI_API_KEY=

# Postgres connection string — free: https://neon.tech (new project -> copy connection string)
# Use the POOLED connection string (host contains "-pooler") for the app.
# Recommended: append &uselibpqcompat=true to silence a pg SSL-mode deprecation warning
# (harmless, dev-only console noise — see the pg package's own suggested fix).
DATABASE_URL=

# Direct (non-pooled) connection — same string with "-pooler" removed from the host.
# Used only by prisma migrate / db push (Neon's pooler can't hold migration locks).
DIRECT_URL=
