// Invoice Trust Layer — data model (see docs/plan.md, decisions D2/D3/D7/D9)
//
// Each extracted field is stored TWICE (D9):
//   - `<field>Field` JSON: { value, modelConfidence, confidence, bbox, flags[] }
//     the trust core (D2) — confidence is EARNED by validation, never self-reported.
//   - a plain typed column for the SEARCHABLE subset (vendorName, total, invoiceDate),
//     indexed for fast structured query (D4). Value mirrored from the JSON on write.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Invoice {
  id      String @id @default(cuid())
  fileUrl String

  // Lifecycle: processing | needs_review | trusted | failed
  status String @default("processing")

  // Base64-encoded PDF bytes, ONLY populated for seeded sample invoices used to demo
  // provenance (click a field -> highlight its source on the page). NEVER set for a real
  // user upload — those are extracted in-memory and discarded (see decisions D21, D22).
  // Stored as base64 text rather than a native `Bytes`/bytea column: @prisma/adapter-pg
  // 7.9.0 fails to deserialize bytea back into a Buffer on read (confirmed via raw SQL —
  // the bytes ARE correctly stored; only Prisma's typed read path chokes on them). Base64
  // text sidesteps the broken binary-type mapping entirely.
  fileData String?

  // --- Searchable projection (D9): typed, indexed, filled from the *Field JSON ---
  vendorName  String?
  total       Decimal? @db.Decimal(14, 2)
  invoiceDate DateTime?

  // --- Per-field trust JSON (D2): { value, modelConfidence, confidence, bbox, flags[] } ---
  vendorNameField  Json?
  vendorGSTINField Json?
  invoiceNoField   Json?
  invoiceDateField Json?
  dueDateField     Json?
  currencyField    Json?
  subtotalField    Json?
  taxRateField     Json?
  taxAmountField   Json?
  totalField       Json?

  lineItems LineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([vendorName])
  @@index([total])
  @@index([invoiceDate])
  @@index([createdAt])
}

model LineItem {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  position  Int // order on the invoice

  // Per-field trust JSON, same shape as Invoice fields (line items aren't
  // searched directly in D4, so no typed projection columns here).
  descriptionField Json?
  quantityField    Json?
  unitPriceField   Json?
  lineAmountField  Json?

  @@index([invoiceId])
}
